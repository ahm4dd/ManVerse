{
  "name": "@manverse/cli",
  "version": "0.1.0",
  "description": "ManVerse CLI (Single Binary Mode)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile dist/manverse",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@manverse/core": "workspace:*",
    "@manverse/adapters-queue": "workspace:*",
    "@manverse/scrapers": "workspace:*",
    "inquirer": "^9.2.14",
    "ora": "^8.0.1",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.3.3"
  }
}
