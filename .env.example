# AniList API Credentials
# Get these from https://anilist.co/settings/developer

ANILIST_CLIENT_ID=your_client_id_here
ANILIST_CLIENT_SECRET=your_client_secret_here

# Optional: Override default redirect URI (default: http://localhost:8888/callback)
# ANILIST_REDIRECT_URI=http://localhost:8888/callback

# Optional: For integration tests
# ANILIST_TEST_TOKEN=your_test_token_here
